LIBRARY ieee;
USE ieee.std_logic_1164.all;

ENTITY Func_soma IS
	PORT (fA : IN BIT_VECTOR(3 DOWNTO 0);
			fS_OUT: OUT BIT_VECTOR(3 DOWNTO 0));
END Func_soma;

ARCHITECTURE somador OF Func_soma IS
	SIGNAL h, l: BIT;
	
	SIGNAL fC_OUT : BIT_VECTOR(3 DOWNTO 0);
	
	COMPONENT soma IS
	PORT (a, b, c_IN : IN BIT;
			s, c_OUT : OUT BIT);
	END COMPONENT soma;
BEGIN
	h <= '1';
	l <= '0';
	soma0: soma PORT MAP(C_IN => l,         a => fA(0), b => h, c_out => fC_OUT(0), s => fS_OUT(0));
	soma1: soma PORT MAP(C_IN => fC_OUT(0), a => fA(1), b => l, c_out => fC_OUT(1), s => fS_OUT(1));
	soma2: soma PORT MAP(C_IN => fC_OUT(1), a => fA(2), b => l, c_out => fC_OUT(2), s => fS_OUT(2));
	soma3: soma PORT MAP(C_IN => fC_OUT(2), a => fA(3), b => l, c_out => fC_OUT(3), s => fS_OUT(3));
END somador;